# Company-specific settings — copy to .env and fill in values
COMPANY_NAME=
WHATSAPP_PHONE_NUMBER=
REPORT_RECIPIENTS=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Use the service_role key (not the anon key) for backend access.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Group registry (required for multi-company isolation) ─────────────────────
# Maps WhatsApp group IDs to company identifiers.
# Format: groupId1:companyId1,groupId2:companyId2
# Get the group ID from the console when the listener first receives a message
# from that group (printed as chat.id._serialized).
# Groups not listed here are ignored — no jobs will be saved, no reports run.
GROUP_REGISTRY=

# ── Default group for CLI report and cron scheduler ──────────────────────────
# Used by: npm run report:weekly, npm run cron:weekly
# Must match one of the group IDs in GROUP_REGISTRY.
TARGET_WHATSAPP_GROUP_ID=

# ── Report recipients ─────────────────────────────────────────────────────────
# MANAGER_REPORT_RECIPIENT: who receives the main weekly summary report.
# DEFAULT_TECHNICIAN_RECIPIENT: fallback recipient for all technician reports
#   until per-technician phone mapping is implemented (Phase 12B).
# For ConsoleReportSender these values are labels only (no real phone needed).
MANAGER_REPORT_RECIPIENT=
DEFAULT_TECHNICIAN_RECIPIENT=
