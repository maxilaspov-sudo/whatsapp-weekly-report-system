# Company-specific settings — copy to .env and fill in values
COMPANY_NAME=
WHATSAPP_PHONE_NUMBER=
REPORT_RECIPIENTS=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Use the service_role key (not the anon key) for backend access.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── WhatsApp group filter ─────────────────────────────────────────────────────
# Set TARGET_WHATSAPP_GROUP_ID for an exact match (preferred).
# Copy the id printed to console when the listener first receives a group message.
# Set TARGET_WHATSAPP_GROUP_NAME for a case-insensitive name substring match.
# If neither is set, all group messages are logged.
TARGET_WHATSAPP_GROUP_ID=
TARGET_WHATSAPP_GROUP_NAME=
